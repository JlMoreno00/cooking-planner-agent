# External API Keys Configuration
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git — it's in .gitignore

# Spoonacular API Key (free tier: 150 points/day)
# Register at: https://spoonacular.com/food-api
# Free tier limits: 150 points/day, ~1-2 points per API call
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Mealie API Token (generated during Mealie setup in Task 1)
# Format: Bearer token from Mealie admin panel
MEALIE_API_TOKEN=your_mealie_api_token_here

# Mealie Base URL (internal network access)
# Default: http://localhost:9925 (if running on same machine)
# Or: http://mealie:9925 (if running in Docker network)
MEALIE_BASE_URL=http://localhost:9925

# OpenClaw Configuration (optional, for MCP integration)
# These will be referenced in .mcp.json or openclaw.json
OPENCLAW_WORKSPACE_PATH=~/.agents

# Google Keep / Google Tasks (for shopping list sync, Task 9)
# If using Google Keep MCP: OAuth token or service account JSON
GOOGLE_KEEP_TOKEN=your_google_keep_token_here

# Telegram Bot Token (configured in Task 4)
# Format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Video recipe extraction MCP (YouTube/TikTok)
VIDEO_RECIPE_MCP_HOST=127.0.0.1
VIDEO_RECIPE_MCP_PORT=9155
VIDEO_RECIPE_WORKDIR=/tmp/video-recipe-mcp
VIDEO_RECIPE_MAX_KEYFRAMES=12

# Optional enhancements
# Used for higher-quality structured extraction from transcript segments
VIDEO_RECIPE_LLM_MODEL=gpt-4o-mini
# Optional fallback transcription model when captions are missing
VIDEO_RECIPE_WHISPER_MODEL=base
